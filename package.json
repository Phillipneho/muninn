{
  "name": "muninn-v2",
  "version": "5.3.0",
  "description": "Memory as evolving reality - Bi-temporal knowledge graph with Supermemory parity",
  "homepage": "https://muninn.au",
  "repository": {
    "type": "git",
    "url": "https://github.com/Phillipneho/muninn.git"
  },
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "muninn-mcp": "dist/mcp-server.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "migrate": "tsx src/migrate-neon.ts",
    "migrate:local": "psql postgresql://muninn:muninn@localhost:5432/muninn_v2 -f src/schema.sql",
    "migrate:neon": "tsx src/migrate-neon.ts",
    "test": "tsx src/test.ts",
    "test:phase1": "tsx src/test-phase1.ts",
    "test:phase2": "tsx src/test-phase2.ts",
    "test:phase3": "tsx src/test-phase3.ts",
    "test:phase4": "tsx src/test-phase4.ts",
    "mcp": "tsx src/mcp-server.ts",
    "setup:local": "./setup.sh local",
    "setup:neon": "./setup.sh neon"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^11.0.0",
    "dotenv": "^16.6.1",
    "openai": "^4.0.0",
    "pg": "^8.11.0",
    "uuid": "^13.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}

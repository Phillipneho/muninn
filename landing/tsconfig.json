{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "resolveJsonModule": true,
    "noEmit": true
  },
  "include": ["api/**/*", "src/**/*"],
  "exclude": ["node_modules"]
}